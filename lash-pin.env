# The benchmark runner crates (bench/*/runner) depend on Lash from the remote
# Git tag pinned in the workspace Cargo.toml.
#
# The `lash` CLI binary that drives Terminal Bench is NOT published to crates.io
# (the lash-cli crate is publish = false), so scripts/run-terminalbench.sh
# installs it from this Git tag. Keep the tag in sync with Cargo.toml.
LASH_GIT_URL=https://github.com/SamGalanakis/lash
LASH_GIT_TAG=v0.1.0-alpha.85
